---
interface Props {
  size?: "sm" | "md" | "lg";
  label?: boolean;
}

const { size = "md", label = true } = Astro.props;
---

<div class:list={["brand-mark", `brand-mark--${size}`]}>
  <span class="brand-mark__icon" aria-hidden="true">
    <svg viewBox="0 0 64 48" role="img">
      <rect x="4" y="12" width="44" height="30" rx="7" fill="currentColor" opacity="0.12"></rect>
      <rect x="10" y="7" width="38" height="29" rx="7" fill="#fff"></rect>
      <rect x="18" y="17" width="36" height="23" rx="6" fill="#0B6B4F"></rect>
      <circle cx="32" cy="28" r="10" fill="#F7F5EF" stroke="#0E1726" stroke-width="4"></circle>
      <circle cx="32" cy="28" r="2.5" fill="#D8A31A"></circle>
      <path d="M32 18v5M32 33v5M22 28h5M37 28h5" stroke="#0E1726" stroke-width="3" stroke-linecap="round"></path>
    </svg>
  </span>
  {label && (
    <span class="brand-mark__text">
      <strong>Bank of Dad</strong>
      <small>Private family ledger</small>
    </span>
  )}
</div>
